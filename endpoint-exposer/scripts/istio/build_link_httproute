#!/bin/bash

set -euo pipefail

source "$SERVICE_PATH/scripts/istio/config"
source "$SERVICE_PATH/scripts/avp/config"

echo "=== Building HTTPRoute for link (scopes: $ALL_SCOPES) ==="

# Fetch all scopes for this application once
ALL_SCOPES_JSON=$(np scope list --application_id "$APPLICATION_ID" --limit 200 --format json | jq '.results // []')

# Collect unique scopes: target_scope per route if set, otherwise ALL_SCOPES
SCOPE_SLUGS=$(echo "$ROUTES_JSON" | jq -r --argjson all_scopes "$ALL_SCOPES" '
  [.[] | if (.target_scope != null and .target_scope != "") then .target_scope else $all_scopes[] end] | unique | .[]')

if [[ -z "$SCOPE_SLUGS" ]]; then
  SCOPE_SLUGS="$SCOPE"
fi

# Resolve all scope domains and determine gateway (use first scope for gateway/visibility)
FIRST_SCOPE=true
HOSTNAMES_YAML=""
SCOPE_DOMAIN=""
SCOPE_ID=""
GATEWAY_NAME="$PUBLIC_GATEWAY_NAME"
HTTPROUTE_SUFFIX="public"

while IFS= read -r SLUG; do
  SID=$(echo "$ALL_SCOPES_JSON" | jq -r --arg name "$SLUG" '.[] | select(.name == $name) | .id')
  if [[ -z "$SID" || "$SID" == "null" ]]; then
    echo "WARNING: Could not resolve scope '$SLUG', skipping"
    continue
  fi
  SDATA=$(np scope read --id "$SID" --format json)
  SDOMAIN=$(echo "$SDATA" | jq -r '.domain // ""')
  if [[ -z "$SDOMAIN" ]]; then
    echo "WARNING: Scope '$SLUG' has no domain, skipping"
    continue
  fi
  HOSTNAMES_YAML+="    - ${SDOMAIN}"$'\n'
  echo "Resolved scope '$SLUG' → domain: $SDOMAIN"

  if [[ "$FIRST_SCOPE" == "true" ]]; then
    SCOPE_ID="$SID"
    SCOPE_DOMAIN="$SDOMAIN"
    SVIS=$(echo "$SDATA" | jq -r '.service.attributes.visibility // "external"')
    if [[ "$SVIS" == "internal" ]]; then
      GATEWAY_NAME="$PRIVATE_GATEWAY_NAME"
      HTTPROUTE_SUFFIX="private"
    fi
    FIRST_SCOPE=false
  fi
done <<< "$SCOPE_SLUGS"

if [[ -z "$SCOPE_DOMAIN" ]]; then
  echo "ERROR: Could not resolve any scope domain"
  exit 1
fi

HTTPROUTE_FILE="$OUTPUT_DIR/httproute-${HTTPROUTE_NAME}-${HTTPROUTE_SUFFIX}.yaml"
cat > "$HTTPROUTE_FILE" <<EOF
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: ${HTTPROUTE_NAME}-${HTTPROUTE_SUFFIX}
  namespace: ${K8S_NAMESPACE}
  labels:
    nullplatform.com/managed-by: endpoint-exposer
    nullplatform.com/service-id: "${SERVICE_ID}"
    app.kubernetes.io/name: ${SERVICE_SLUG}
spec:
  parentRefs:
    - name: ${GATEWAY_NAME}
      namespace: ${GATEWAY_NAMESPACE}
      group: gateway.networking.k8s.io
      kind: Gateway
  hostnames:
${HOSTNAMES_YAML}  rules: []
EOF

# Expand routes: one entry per scope for process_routes (backwards compat: scope as string)
# Expand routes: if target_scope is set use it, otherwise expand across ALL_SCOPES
EXPANDED_ROUTES=$(echo "$ROUTES_JSON" | jq -c --argjson all_scopes "$ALL_SCOPES" '
  [.[] | . as $route |
    if ($route.target_scope != null and $route.target_scope != "") then
      [$route.target_scope]
    else
      $all_scopes
    end | .[] | $route + {scope: .}]')
export ROUTES_JSON="$EXPANDED_ROUTES"
export HTTPROUTE_FILE
source "$SERVICE_PATH/scripts/istio/process_routes"
echo "✅ HTTPRoute ${HTTPROUTE_NAME}-${HTTPROUTE_SUFFIX} created ($(echo "$EXPANDED_ROUTES" | jq 'length') rules)"

HTTPROUTE_NAME="${HTTPROUTE_NAME}-${HTTPROUTE_SUFFIX}"
export SCOPE_ID
export SCOPE_DOMAIN
export HTTPROUTE_NAME
