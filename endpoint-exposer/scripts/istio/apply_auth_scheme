#!/bin/bash

set -euo pipefail

source "$SERVICE_PATH/scripts/istio/config"

AUTH_TYPE="${AUTH_TYPE:-}"
COGNITO_USER_POOL_ARN="${COGNITO_USER_POOL_ARN:-}"
OUTPUT_DIR="${OUTPUT_DIR:-/tmp/endpoint-exposer-auth}"

mkdir -p "$OUTPUT_DIR"

# Parse Cognito ARN → region + pool_id
# Format: arn:aws:cognito-idp:{region}:{account}:userpool/{pool_id}
_parse_cognito_arn() {
  local arn="$1"
  COGNITO_REGION=$(echo "$arn" | cut -d: -f4)
  COGNITO_POOL_ID=$(echo "$arn" | cut -d/ -f2)
  COGNITO_ISSUER="https://cognito-idp.${COGNITO_REGION}.amazonaws.com/${COGNITO_POOL_ID}"
  COGNITO_JWKS_URI="${COGNITO_ISSUER}/.well-known/jwks.json"
}

_render_deny_all() {
  local gateway_name="$1"
  local suffix="$2"
  local out_file="$OUTPUT_DIR/deny-all-${suffix}.yaml"

  local context
  context=$(jq -n \
    --arg gateway_name "$gateway_name" \
    --arg gateway_namespace "$GATEWAY_NAMESPACE" \
    --arg suffix "$suffix" \
    '{gateway_name: $gateway_name, gateway_namespace: $gateway_namespace, suffix: $suffix}')

  local ctx_file="$OUTPUT_DIR/deny-all-${suffix}-ctx.json"
  echo "$context" > "$ctx_file"
  gomplate -c ".=$ctx_file" \
    -f "$SERVICE_PATH/templates/istio/deny-all.yaml.tpl" \
    -o "$out_file"
  rm "$ctx_file"
  echo "$out_file"
}

_render_request_authentication() {
  local gateway_name="$1"
  local suffix="$2"
  local out_file="$OUTPUT_DIR/request-authentication-${suffix}.yaml"

  local context
  context=$(jq -n \
    --arg gateway_name "$gateway_name" \
    --arg gateway_namespace "$GATEWAY_NAMESPACE" \
    --arg suffix "$suffix" \
    --arg issuer "$COGNITO_ISSUER" \
    --arg jwks_uri "$COGNITO_JWKS_URI" \
    '{gateway_name: $gateway_name, gateway_namespace: $gateway_namespace, suffix: $suffix, issuer: $issuer, jwks_uri: $jwks_uri}')

  local ctx_file="$OUTPUT_DIR/request-authentication-${suffix}-ctx.json"
  echo "$context" > "$ctx_file"
  gomplate -c ".=$ctx_file" \
    -f "$SERVICE_PATH/templates/istio/request-authentication.yaml.tpl" \
    -o "$out_file"
  rm "$ctx_file"
  echo "$out_file"
}

# Validate AUTH_TYPE
if [[ -z "$AUTH_TYPE" ]]; then
  echo "ERROR: AUTH_TYPE is not set (expected: aws-avp | aws-cognito)"
  exit 1
fi

if [[ "$AUTH_TYPE" != "aws-avp" && "$AUTH_TYPE" != "aws-cognito" ]]; then
  echo "ERROR: Unknown AUTH_TYPE='$AUTH_TYPE' (expected: aws-avp | aws-cognito)"
  exit 1
fi

DENY_PUBLIC_TRAFFIC="${DENY_PUBLIC_TRAFFIC:-true}"
DENY_PRIVATE_TRAFFIC="${DENY_PRIVATE_TRAFFIC:-true}"

# Validate at least one gateway is protected
if [[ "$DENY_PUBLIC_TRAFFIC" != "true" && "$DENY_PRIVATE_TRAFFIC" != "true" ]]; then
  echo "ERROR: At least one of deny_public_traffic or deny_private_traffic must be enabled."
  exit 1
fi

echo "=== Applying auth scheme: $AUTH_TYPE (deny_public=$DENY_PUBLIC_TRAFFIC, deny_private=$DENY_PRIVATE_TRAFFIC) ==="

# Build list of active gateways
ACTIVE_GATEWAYS=()
[[ "$DENY_PUBLIC_TRAFFIC" == "true" ]] && ACTIVE_GATEWAYS+=("$PUBLIC_GATEWAY_NAME")
[[ "$DENY_PRIVATE_TRAFFIC" == "true" ]] && ACTIVE_GATEWAYS+=("$PRIVATE_GATEWAY_NAME")

# Apply deny-all on selected gateways
for gateway_name in "${ACTIVE_GATEWAYS[@]}"; do
  suffix="${gateway_name##gateway-}"
  echo "Generating deny-all for $gateway_name..."
  deny_all_file=$(_render_deny_all "$gateway_name" "$suffix")
  kubectl apply -f "$deny_all_file"
  echo "✅ deny-all-${suffix} applied"
done

# Apply RequestAuthentication only for aws-cognito on selected gateways
if [[ "$AUTH_TYPE" == "aws-cognito" ]]; then
  if [[ -z "$COGNITO_USER_POOL_ARN" ]]; then
    echo "ERROR: COGNITO_USER_POOL_ARN is required for auth_type=aws-cognito"
    exit 1
  fi

  _parse_cognito_arn "$COGNITO_USER_POOL_ARN"
  echo "Cognito pool: $COGNITO_POOL_ID (region: $COGNITO_REGION)"

  for gateway_name in "${ACTIVE_GATEWAYS[@]}"; do
    suffix="${gateway_name##gateway-}"
    echo "Generating RequestAuthentication for $gateway_name..."
    ra_file=$(_render_request_authentication "$gateway_name" "$suffix")
    kubectl apply -f "$ra_file"
    echo "✅ cognito-jwt-${suffix} applied"
  done
fi

echo "=== Auth scheme '$AUTH_TYPE' applied successfully ==="
