#!/bin/bash

set -euo pipefail

SERVICE_ID=$(echo "$CONTEXT" | jq -r .service.id)
SERVICE_SLUG=$(echo "$CONTEXT" | jq -r .service.slug)

ACTION_ID=$(echo "$CONTEXT" | jq -r .id)
ACTION_NAME=$(echo "$CONTEXT" | jq -r .slug)

K8S_NAMESPACE="${NAMESPACE_OVERRIDE:-nullplatform}"
APPLICATION_ID=$(echo "$CONTEXT" | jq -r '.tags.application_id // ""')

# Extract routes array from parameters
ROUTES_JSON=$(echo "$CONTEXT" | jq -c '.parameters.routes // []')

# Split routes by visibility
PUBLIC_ROUTES_JSON=$(echo "$ROUTES_JSON" | jq -c '[.[] | select(.visibility == "public" or .visibility == null)]')
PRIVATE_ROUTES_JSON=$(echo "$ROUTES_JSON" | jq -c '[.[] | select(.visibility == "private")]')

CONTEXT=$(echo "$CONTEXT" | jq \
          --arg k8s_namespace "$K8S_NAMESPACE" \
          '. + {k8s_namespace: $k8s_namespace}')

# Only set OUTPUT_DIR if not already set (allows tests to override)
if [[ -z "${OUTPUT_DIR:-}" ]]; then
  export OUTPUT_DIR="$SERVICE_PATH/output/$SERVICE_SLUG-$SERVICE_ID/$ACTION_NAME-$ACTION_ID"
fi

mkdir -p "$OUTPUT_DIR"

AUTH_TYPE=$(echo "$CONTEXT" | jq -r '
  .parameters.auth_type //
  .notification.parameters.auth_type //
  .service.attributes.auth_type //
  "aws-avp"')

COGNITO_USER_POOL_ARN=$(echo "$CONTEXT" | jq -r '
  .parameters.cognito_user_pool_arn //
  .notification.parameters.cognito_user_pool_arn //
  .service.attributes.cognito_user_pool_arn //
  ""')

AVP_POLICY_STORE_ARN=$(echo "$CONTEXT" | jq -r '
  .parameters.avp_policy_store_arn //
  .notification.parameters.avp_policy_store_arn //
  .service.attributes.avp_policy_store_arn //
  ""')
AVP_POLICY_STORE_ID=$(echo "$AVP_POLICY_STORE_ARN" | cut -d'/' -f2)

export SERVICE_ID
export SERVICE_SLUG
export ACTION_ID
export ACTION_NAME
export APPLICATION_ID
export ROUTES_JSON
export PUBLIC_ROUTES_JSON
export PRIVATE_ROUTES_JSON
export AUTH_TYPE
export COGNITO_USER_POOL_ARN
export AVP_POLICY_STORE_ID

DENY_PUBLIC_TRAFFIC=$(echo "$CONTEXT" | jq -r '
  .notification.parameters.deny_public_traffic //
  .parameters.deny_public_traffic //
  .service.attributes.deny_public_traffic //
  true')
DENY_PRIVATE_TRAFFIC=$(echo "$CONTEXT" | jq -r '
  .notification.parameters.deny_private_traffic //
  .parameters.deny_private_traffic //
  .service.attributes.deny_private_traffic //
  true')
export DENY_PUBLIC_TRAFFIC
export DENY_PRIVATE_TRAFFIC