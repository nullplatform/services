#!/bin/bash

set -euo pipefail

source "$SERVICE_PATH/scripts/avp/config"

POLICY_ID="${ACTION_LINK_ATTRIBUTES_POLICY_ID:-}"

if [[ -z "$POLICY_ID" || "$POLICY_ID" == "null" ]]; then
  echo "WARNING: No policy_id found in link attributes, skipping Cedar policy deletion"
  exit 0
fi

echo "Deleting Cedar policy: $POLICY_ID"
aws verifiedpermissions delete-policy \
  --policy-store-id "$AVP_POLICY_STORE_ID" \
  --region "$AVP_AWS_REGION" \
  --policy-id "$POLICY_ID" || { echo "WARNING: Failed to delete policy $POLICY_ID (may already be deleted)"; }

echo "✅ Cedar policy $POLICY_ID deleted"
