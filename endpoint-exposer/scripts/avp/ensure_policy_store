#!/bin/bash

set -euo pipefail

source "$SERVICE_PATH/scripts/avp/config"

CONTEXT="${CONTEXT:-${NP_ACTION_CONTEXT:-}}"

CONFIGURED_ID=$(echo "$CONTEXT" | jq -r '
  .parameters.avp_policy_store_id //
  .notification.parameters.avp_policy_store_id //
  .service.attributes.avp_policy_store_id //
  ""')

if [[ -z "$CONFIGURED_ID" ]]; then
  echo "ERROR: avp_policy_store_id is required. Set it in the service attributes when creating the service." >&2
  exit 1
fi

echo "Using AVP policy store: $CONFIGURED_ID"
export AVP_POLICY_STORE_ID="$CONFIGURED_ID"
