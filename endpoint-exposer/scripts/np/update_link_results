#!/bin/bash

set -euo pipefail

CONTEXT="${CONTEXT:-${NP_ACTION_CONTEXT:-}}"
AUTH_TYPE="${AUTH_TYPE:-aws-avp}"
POLICY_IDS="${POLICY_IDS:-}"

RESULTS=$(echo "$CONTEXT" | jq \
  --arg httproute_name "$HTTPROUTE_NAME" \
  --arg policy_ids "$POLICY_IDS" \
  --arg scope "$SCOPE" \
  '(.notification.parameters // .parameters // {}) + {
    httproute_name: $httproute_name,
    policy_ids: $policy_ids,
    scope: $scope,
    routes: ((.notification.parameters // .parameters // {}).routes // [] | to_entries | map(
      .value + {
        summary: (
          "Rule #" + ((.key + 1) | tostring) + " — " +
          (.value.path // "") + " | " +
          (if (.value.methods | type) == "array" then (.value.methods | join(", ")) else (.value.method // "") end) + " | " +
          (if (.value.scopes | type) == "array" then (.value.scopes | join(", ")) elif (.value.scope != null) then .value.scope else "" end) + " | " +
          (.value.groups // "")
        )
      }
    ))
  }')

echo "Storing link results: httproute_name=$HTTPROUTE_NAME, scope=$SCOPE, auth_type=$AUTH_TYPE"
np link action update --results "$RESULTS"
echo "✅ Link results stored"
