#!/bin/bash

set -euo pipefail

echo "=== Build Permissions Context ==="
echo "Access Level: $LINK_ACCESS_LEVEL"
echo "All Containers: $LINK_ALL_CONTAINERS"
echo "Selected Containers: $LINK_SELECTED_CONTAINERS"
echo "Database: $DATABASE_NAME"
echo "Account: $ACCOUNT_NAME"
echo "Resource Group: $RESOURCE_GROUP"

# Get the principal ID from the scope context
PRINCIPAL_ID="${SCOPE_PRINCIPAL_ID:-}"

if [ -z "$PRINCIPAL_ID" ]; then
  echo "ERROR: SCOPE_PRINCIPAL_ID is not set. Cannot assign role without a principal."
  exit 1
fi

echo "Principal ID: $PRINCIPAL_ID"

# Determine target containers
if [ "$LINK_ALL_CONTAINERS" = "true" ]; then
  echo "Using all containers from service definition"

  # Extract container names from ALL_CONTAINERS (service parameters)
  CONTAINERS_TO_APPLY_PERMISSIONS=$(echo "$ALL_CONTAINERS" | jq -c '[.[].containerName]')

  echo "Found containers: $CONTAINERS_TO_APPLY_PERMISSIONS"
else
  CONTAINERS_TO_APPLY_PERMISSIONS="$LINK_SELECTED_CONTAINERS"
  echo "Using selected containers: $CONTAINERS_TO_APPLY_PERMISSIONS"
fi

# Validate we have containers
CONTAINER_COUNT=$(echo "$CONTAINERS_TO_APPLY_PERMISSIONS" | jq 'length')
if [ "$CONTAINER_COUNT" -eq 0 ]; then
  echo "ERROR: No containers specified"
  exit 1
fi

# Build tfvars for permissions module
TOFU_VARIABLES=$(jq -n \
  --arg subscription_id "$SUBSCRIPTION_ID" \
  --arg resource_group_name "$RESOURCE_GROUP" \
  --arg cosmos_account_name "$ACCOUNT_NAME" \
  --arg database_name "$DATABASE_NAME" \
  --arg principal_id "$PRINCIPAL_ID" \
  --arg access_level "$LINK_ACCESS_LEVEL" \
  --argjson all_containers "$LINK_ALL_CONTAINERS" \
  --argjson containers_to_apply_permissions "$CONTAINERS_TO_APPLY_PERMISSIONS" \
  '{
    subscription_id: $subscription_id,
    resource_group_name: $resource_group_name,
    cosmos_account_name: $cosmos_account_name,
    database_name: $database_name,
    principal_id: $principal_id,
    access_level: $access_level,
    all_containers: $all_containers,
    containers_to_apply_permissions: $containers_to_apply_permissions
  }')

echo "Generated tfvars:"
echo "$TOFU_VARIABLES" | jq .

# Set module directory for permissions
TOFU_MODULE_DIR="$SERVICE_PATH/permissions"

# Backend config for tfstate (values from environment, if configured)
if [ -n "${AZURE_TFSTATE_STORAGE_ACCOUNT:-}" ] && [ -n "${AZURE_TFSTATE_CONTAINER:-}" ]; then
  echo "Using Azure backend for tfstate"

  TFSTATE_RESOURCE_GROUP="${AZURE_TFSTATE_RESOURCE_GROUP:-$RESOURCE_GROUP}"
  TFSTATE_KEY="cosmos-db/${SERVICE_ID}/links/${LINK_ID}/permissions.tfstate"

  # Generate backend.tf dynamically
  cat > "$TOFU_MODULE_DIR/backend.tf" <<EOF
terraform {
  backend "azurerm" {}
}
EOF

  TOFU_INIT_VARIABLES="-backend-config=resource_group_name=${TFSTATE_RESOURCE_GROUP} -backend-config=storage_account_name=${AZURE_TFSTATE_STORAGE_ACCOUNT} -backend-config=container_name=${AZURE_TFSTATE_CONTAINER} -backend-config=key=${TFSTATE_KEY}"
else
  echo "Using local backend for tfstate"

  # Remove backend.tf if exists to use local backend
  rm -f "$TOFU_MODULE_DIR/backend.tf"

  TOFU_INIT_VARIABLES=""
fi

# Create output directory for permissions
PERMISSIONS_OUTPUT_DIR="$OUTPUT_DIR/permissions"
mkdir -p "$PERMISSIONS_OUTPUT_DIR"

export TOFU_MODULE_DIR
export TOFU_VARIABLES
export TOFU_INIT_VARIABLES
export OUTPUT_DIR="$PERMISSIONS_OUTPUT_DIR"

echo "=== Permissions context ready ==="
