#!/bin/bash
set -euo pipefail

SERVICE_ID=$(echo "$CONTEXT" | jq -r '.service.id')
SERVICE_SLUG=$(echo "$CONTEXT" | jq -r '.service.slug')
ACTION_ID=$(echo "$CONTEXT" | jq -r '.id')
ACTION_NAME=$(echo "$CONTEXT" | jq -r '.slug')
APPLICATION_ID=$(echo "$CONTEXT" | jq -r '.tags.application_id // ""')

PATH_PREFIX=$(echo "$CONTEXT" | jq -r '.link.attributes.path_prefix // .parameters.path_prefix // ""')
SCOPE_SLUG=$(echo "$CONTEXT" | jq -r '.link.attributes.scope // .parameters.scope // ""')

BASE_DOMAIN=$(echo "$CONTEXT" | jq -r '.service.attributes.base_domain // .parameters.base_domain // ""')
GATEWAY=$(echo "$CONTEXT" | jq -r '.service.attributes.gateway // "public"')
STRIP_PREFIX=$(echo "$CONTEXT" | jq -r '.service.attributes.strip_prefix // "true"')

[[ -z "$BASE_DOMAIN" ]] && { echo "ERROR: base_domain is required in service attributes"; exit 1; }
[[ -z "$PATH_PREFIX" ]] && { echo "ERROR: path_prefix is required in link attributes"; exit 1; }
[[ -z "$SCOPE_SLUG" ]] && { echo "ERROR: scope is required in link attributes"; exit 1; }

echo "Resolving scope '$SCOPE_SLUG' for application $APPLICATION_ID..."
SCOPES_JSON=$(np scope list --application_id "$APPLICATION_ID" --limit 200 --format json | jq '.results // []')
SCOPE_ID=$(echo "$SCOPES_JSON" | jq -r --arg s "$SCOPE_SLUG" '.[] | select(.slug == $s) | .id')

if [[ -z "$SCOPE_ID" || "$SCOPE_ID" == "null" ]]; then
    echo "ERROR: Could not find scope with slug '$SCOPE_SLUG' for application $APPLICATION_ID"
    exit 1
fi
echo "Resolved scope: $SCOPE_SLUG → $SCOPE_ID"

if [[ -z "${OUTPUT_DIR:-}" ]]; then
    export OUTPUT_DIR="$SERVICE_PATH/output/$SERVICE_SLUG-$SERVICE_ID/$ACTION_NAME-$ACTION_ID"
fi
mkdir -p "$OUTPUT_DIR"

export SERVICE_ID SERVICE_SLUG ACTION_ID ACTION_NAME APPLICATION_ID
export PATH_PREFIX SCOPE_SLUG SCOPE_ID BASE_DOMAIN GATEWAY STRIP_PREFIX
